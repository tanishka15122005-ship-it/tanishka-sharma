    return 0;
}

Factorial Of a Number
#include <iostream>

int factorial(int n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

int main() {
    int number = 5;
    
    int result = factorial(number);
    
    std::cout << result << "\n";
    
    return 0;
}

Fibonacci Series 
#include <iostream>

int fibonacci(int n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main() {
    int n = 10;
    
    for (int i = 0; i < n; ++i) {
        std::cout << fibonacci(i) << " ";
    }
    
    std::cout << "\n";
    
    return 0;
}

LeetCode 70
Climbing stairs 
class Solution {
private:
    int recursive(int n, int curr) {
        if (curr == n) {
            return 1;
        }
        if (curr > n) {
            return 0;
        }

        return recursive(n, curr + 1) + recursive(n, curr + 2);
    }

public:
    int climbStairs(int n) {
        return recursive(n, 0);
    }
};
